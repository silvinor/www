root = true

[*]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 4
tab_width = 4

[*.{svg,xml,xsl}]
insert_final_newline = false

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
